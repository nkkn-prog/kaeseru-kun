// Prisma スキーマ定義
// docs/database-schema.md に基づいて定義

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// ユーザープロフィール（auth.users の拡張）
model Profile {
  id        String   @id @db.Uuid
  name      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  debts           Debt[]
  screenshots     Screenshot[]
  transactions    Transaction[]
  incomes         Income[]
  monthlyAnalyses MonthlyAnalysis[]

  @@map("profiles")
}

/// 借金情報
model Debt {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String
  lender         String?
  currentBalance Int      @map("current_balance")
  interestRate   Decimal? @map("interest_rate") @db.Decimal(5, 2)
  interestType   String?  @map("interest_type")
  monthlyPayment Int?     @map("monthly_payment")
  dueDay         Int?     @map("due_day")
  debtType       String   @default("other") @map("debt_type")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz

  profile     Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  screenshots Screenshot[]

  @@map("debts")
}

/// アップロードされたスクリーンショット
model Screenshot {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  debtId      String?   @map("debt_id") @db.Uuid
  storagePath String    @map("storage_path")
  status      String    @default("pending")
  processedAt DateTime? @map("processed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  profile      Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt         Debt?         @relation(fields: [debtId], references: [id], onDelete: SetNull)
  transactions Transaction[]
  incomes      Income[]

  @@map("screenshots")
}

/// 支出記録
model Transaction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  screenshotId    String?  @map("screenshot_id") @db.Uuid
  amount          Int
  description     String?
  category        String?
  transactionDate DateTime @map("transaction_date") @db.Date
  isEssential     Boolean? @map("is_essential")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  profile    Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  screenshot Screenshot? @relation(fields: [screenshotId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

/// 収入記録
model Income {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  screenshotId String?  @map("screenshot_id") @db.Uuid
  amount       Int
  incomeType   String   @default("other") @map("income_type")
  incomeDate   DateTime @map("income_date") @db.Date
  description  String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  profile    Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  screenshot Screenshot? @relation(fields: [screenshotId], references: [id], onDelete: SetNull)

  @@map("incomes")
}

/// 月次AI分析結果
model MonthlyAnalysis {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  yearMonth        String   @map("year_month")
  totalIncome      Int?     @map("total_income")
  totalExpenses    Int?     @map("total_expenses")
  totalDebt        Int?     @map("total_debt")
  debtRatio        Decimal? @map("debt_ratio") @db.Decimal(5, 2)
  unnecessaryTotal Int?     @map("unnecessary_total")
  potentialSavings Int?     @map("potential_savings")
  recommendations  Json?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, yearMonth])
  @@map("monthly_analyses")
}
